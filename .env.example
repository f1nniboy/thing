## ------------------------------------
## general
## ------------------------------------

# Discord bot token
DISCORD_TOKEN=

# comma-separated Discord user IDs with admin access to /thing commands
ALLOWED_USERS=1234567890,...

# prefix character for custom commands
#COMMAND_PREFIX=$

# directory for source files and their databases
#DATA_DIR=./data


## ------------------------------------
## ollama
## ------------------------------------

# model name
# - must have tool support
# - should be a thinking model for best results
OLLAMA_MODEL=gpt-oss:20b

# server URL
#OLLAMA_HOST=http://localhost:11434
# set to OLLAMA_HOST=https://ollama.com for cloud-only models

# API key, required for cloud-only Ollama and web agent tools
# get one at https://ollama.com/signin
#OLLAMA_API_KEY=

#OLLAMA_TEMPERATURE=0.6
#OLLAMA_TOP_P=0.95


## ------------------------------------
## behavior
## ------------------------------------

# max tool calls the agent may make per run
#MAX_TOOL_CALLS=40

# max seconds a command or event handler may run before being cancelled
#HANDLER_TIMEOUT=60
